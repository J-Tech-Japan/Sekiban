{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Amazon": "Warning",
      "Amazon.Runtime": "Warning",
      "Orleans": "Warning",
      "Orleans.Streams": "Warning",
      "DcbOrleansDynamoDB.WithoutResult.ApiService": "Information"
    }
  },
  "AllowedHosts": "*",
  "Sekiban": {
    "Database": "sqlite",
    "ColdEvent": {
      "Enabled": false,
      "PullInterval": "00:30:00",
      "SafeWindow": "00:02:00",
      "SegmentMaxEvents": 30000,
      "ExportMaxEventsPerRun": 30000,
      "SegmentMaxBytes": 536870912,
      "Storage": {
        "Provider": "azureblob",
        "Format": "jsonl",
        "Type": "azureblob",
        "AzureBlobClientName": "MultiProjectionOffload",
        "AzureContainerName": "multiprojection-cold-events"
      }
    }
  }
}
