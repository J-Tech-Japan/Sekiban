{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Azure": "Warning",
      "Azure.Core": "Error",
      "Azure.Storage": "Error",
      "Orleans": "Warning",
      "Orleans.Streams": "Warning",
      "Orleans.Hosting": "Warning",
      "Orleans.AzureUtils": "Error",
      "Orleans.AzureUtils.AzureQueueDataManager": "Error",
      "DcbOrleans.ApiService": "Information",
      "Sekiban.Dcb.Orleans": "Information"
    }
  },
  "Orleans": {
    "UseInMemoryStreams": true
  },
  "Sekiban": {
    "ColdEvent": {
      "Enabled": true,
      "Storage": {
        "Provider": "azureblob",
        "Format": "jsonl",
        "Type": "azureblob",
        "AzureBlobClientName": "MultiProjectionOffload",
        "AzureContainerName": "multiprojection-cold-events"
      }
    }
  }
}
