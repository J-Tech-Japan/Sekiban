#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

project_dir="${PLAYWRIGHT_CLI_PROJECT_DIR:-}"
if [[ "${1:-}" == "--project-dir" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "Missing value for --project-dir" >&2
    exit 1
  fi
  project_dir="$2"
  shift 2
fi

if [[ -z "$project_dir" ]]; then
  project_dir="dcb/internalUsages/DcbOrleans.Benchmark.Playwright"
fi

if [[ "$project_dir" != /* ]]; then
  project_dir="$repo_root/$project_dir"
fi

if [[ ! -f "$project_dir/package.json" ]]; then
  echo "Playwright project not found: $project_dir" >&2
  exit 1
fi

playwright_bin="$project_dir/node_modules/.bin/playwright"
if [[ ! -x "$playwright_bin" ]]; then
  echo "Installing Playwright dependencies in $project_dir" >&2
  npm ci --prefix "$project_dir" >&2
fi

exec "$playwright_bin" "$@"
