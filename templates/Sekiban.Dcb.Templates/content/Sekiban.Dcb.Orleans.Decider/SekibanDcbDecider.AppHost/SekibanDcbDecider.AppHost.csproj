<Project Sdk="Aspire.AppHost.Sdk/13.2.2">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsAspireHost>true</IsAspireHost>
        <RootNamespace>SekibanDcbOrleans.AppHost</RootNamespace>
    </PropertyGroup>

    <PropertyGroup Condition="'$(BENCHMARK_PROFILE)' != ''">
        <DefineConstants>$(DefineConstants);BENCHMARK_PROFILE_ACTIVE</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Aspire.Hosting" Version="13.2.2" />
        <PackageReference Include="Aspire.Hosting.Azure.Storage" Version="13.2.2" />
        <PackageReference Include="Aspire.Hosting.JavaScript" Version="13.2.2" />
        <PackageReference Include="Aspire.Hosting.Orleans" Version="13.2.2" />
        <PackageReference Include="Aspire.Hosting.PostgreSQL" Version="13.2.2" />
        <PackageReference Include="CommunityToolkit.Aspire.Hosting.PostgreSQL.Extensions" Version="13.1.1" />
        <PackageReference Update="Microsoft.SourceLink.GitHub" Version="10.0.103" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SekibanDcbDecider.ApiService\SekibanDcbDecider.ApiService.csproj" />
        <ProjectReference Include="..\SekibanDcbDecider.Web\SekibanDcbDecider.Web.csproj"
                          Condition="'$(BENCHMARK_PROFILE)' == ''" />
    </ItemGroup>

</Project>
